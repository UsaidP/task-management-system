{
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "buildArgs": {
      "VITE_API_URL": "${VITE_API_URL}"
    }
  },
  "deploy": {
    "numReplicas": 1,
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE",
    "startCommand": "dumb-init nginx -g 'daemon off;'"
  }
}