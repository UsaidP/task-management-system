# ===================================
# TaskFlow - Production Environment Variables
# Copy this file to .env and update values
# ===================================

# ===================================
# Docker Configuration
# ===================================
PORT=80

# ===================================
# MongoDB Configuration
# ===================================
# MongoDB Cloud connection string
# Format: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/taskflow?retryWrites=true&w=majority

# ===================================
# JWT Configuration
# ===================================
# Generate secure random strings for production!
# Use: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key-change-in-production
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ===================================
# Hash Pepper (for password hashing)
# ===================================
HASH_PEPPER=your-hash-pepper-change-in-production

# ===================================
# CORS Configuration
# ===================================
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost,http://localhost:80,https://yourdomain.com

# ===================================
# ImageKit Configuration (for file uploads)
# ===================================
# Get these from https://imagekit.io
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# ===================================
# Email Configuration
# ===================================
# OPTION 1: Resend API (Recommended for Railway/cloud hosting)
# Get API key from https://resend.com
RESEND_API_KEY=your_resend_api_key
RESEND_FROM=noreply@yourdomain.com  # Verified domain on Resend

# OPTION 2: SMTP (Local development only)
# Railway blocks outbound SMTP — use Resend for production
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password
MAIL_FROM=noreply@taskflow.com

# ===================================
# Base URL
# ===================================
# Backend API URL (internal Docker network)
BASE_URL=http://backend:3000



# ===================================
# TaskFlow - Development Environment Variables
# ===================================

# ===================================
# Server Configuration
# ===================================
PORT=4000
NODE_ENV=development

# ===================================
# MongoDB Configuration
# ===================================
MONGODB_URI=mongodb+srv://usaid:usaid123@cluster0.j4jel.mongodb.net/?appName=TaskFlow

# ===================================
# JWT Configuration
# ===================================
JWT_SECRET=ayesha
REFRESH_TOKEN_SECRET=ayesha
ACCESS_TOKEN_EXPIRY=7d
REFRESH_TOKEN_EXPIRY=30d
TEMPORARY_TOKEN_EXPIRY=20m
BLACKLISTED_TOKEN_EXPIRY=1d

# ===================================
# Hash Pepper (for password hashing)
# ===================================
HASH_PEPPER=ayesha

# ===================================
# CORS & Base URL
# ===================================
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
BASE_URL=http://localhost:4000
VITE_API_URL=http://localhost:4000/api/v1

# ===================================
# ImageKit Configuration
# ===================================
IMAGEKIT_PUBLIC_KEY=public_J5Hd7eCKkMA9wJj8Smj/TL0Srbk=
IMAGEKIT_PRIVATE_KEY=private_XJ/0D6KMN9mrDG18tEOPlkBQKb4=
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/ptms
IMAGEKIT_AVATAR_FOLDER=avatars
