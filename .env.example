# ===================================
# TaskFlow - Production Environment Variables
# Copy this file to .env and update values
# ===================================

# ===================================
# Docker Configuration
# ===================================
PORT=80

# ===================================
# MongoDB Configuration
# ===================================
MONGO_USERNAME=admin
MONGO_PASSWORD=change-this-in-production-123

# ===================================
# JWT Configuration
# ===================================
# Generate secure random strings for production!
# Use: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key-change-in-production
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ===================================
# Hash Pepper (for password hashing)
# ===================================
HASH_PEPPER=your-hash-pepper-change-in-production

# ===================================
# CORS Configuration
# ===================================
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost,http://localhost:80,https://yourdomain.com

# ===================================
# ImageKit Configuration (for file uploads)
# ===================================
# Get these from https://imagekit.io
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# ===================================
# Email Configuration (SMTP)
# ===================================
# Configure your SMTP server details
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password
MAIL_FROM=noreply@taskflow.com

# ===================================
# Base URL
# ===================================
# Backend API URL (internal Docker network)
BASE_URL=http://backend:3000
