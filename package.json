  "bugs": {
    "url": "https://github.com/UsaidP/task-management-system/issues"
  },
  "homepage": "https://github.com/UsaidP/task-management-system#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "@animateicons/react": "^0.3.3",
    "graphify": "^1.0.0"
  }
